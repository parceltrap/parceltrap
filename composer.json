{
    "name": "parceltrap/parceltrap",
    "type": "library",
    "description": "A driver-based parcel tracking library for PHP",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.10",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "spatie/laravel-data": "^4.20",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.4",
        "phpstan/phpstan": "^2.1.45",
        "symfony/var-dumper": "^7.4|^8.0"
    },
    "autoload": {
        "psr-4": {
            "ParcelTrap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ParcelTrap\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:types": "phpstan analyse --ansi --memory-limit=-1",
        "test:unit": "pest --colors=always",
        "test": [
            "@test:types",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "ParcelTrap\\ParcelTrapServiceProvider"
            ],
            "aliases": {
                "ParcelTrap": "ParcelTrap\\Facades\\ParcelTrap"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
